# ===== PRODUÇÃO "puxadinho" — Meus Exames =====
# Mesmo EC2 do EdEspeto, mesmo domínio (janocaminho), num sub-caminho /meus-exames.
# Reaproveita o Postgres existente (janocaminho-postgres) com um BANCO novo.

# --- Banco (janocaminho-postgres JÁ existe; criou o banco "meus_exames") ---
DATABASE_URL=postgresql://meus_exames:SENHA_DO_BANCO@host.docker.internal:5432/meus_exames?schema=public

# --- App ---
NODE_ENV=production
PORT=4001
UPLOAD_DIR=./data/exams
WEB_ORIGIN=https://janocaminho.com.br
WEB_BASE_PATH=/meus-exames

# --- Sub-caminho do domínio (deploy.sh deriva VITE_BASE/API_URL daqui) ---
# Sugestões impactantes: meus-exames | minhasaude | dr-exame | saude | vitalis | checkup | bemestar
SUBPATH=meus-exames

# --- Push notifications (Firebase — copie a key do EdEspeto) ---
FIREBASE_SERVICE_ACCOUNT_PATH=./keys/firebase-adminsdk.json

# --- Segredos (gere fortes: openssl rand -hex 32) ---
JWT_SECRET=
APP_ENCRYPTION_KEY=

# --- IA (mesmo relay que você usa) ---
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=claude-opus-4-8
EXTRACTION_MODEL=claude-opus-4-8

# --- Armazenamento S3 (mesmo bucket do EdEspeto, pasta isolada) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
S3_REGION=
S3_PREFIX=meus-exames/

# --- E-mail transacional (Zoho) ---
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=contato@chamanoespeto.com.br
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=Meus Exames <contato@chamanoespeto.com.br>

# --- Pagamento (Mercado Pago — mesmo token da sua loja) ---
MP_ACCESS_TOKEN=APP_USR...
MP_API_BASE_URL=https://api.mercadopago.com
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=https://janocaminho.com.br/meus-exames/api/billing/webhook
FREE_EXAM_LIMIT=2

# --- 1º usuário (admin) ---
SEED_EMAIL=
SEED_PASSWORD=
SEED_NAME=
