# ===== IA (camada de abstração llm/ — troca de provider só aqui) =====
# Provider ativo: anthropic (padrão, Z.ai/GLM) | openai | gemini.
# Pra trocar (ex.: assinatura/chave cair): mude AI_PROVIDER + a chave do provider escolhido.
#   Sem mexer em código. Funcionalidades que usam IA: chat (Dr. Exame), extração de exames,
#   relatório consolidado, health-summary, plano de ação, nudges, "explicar item".
#   Detalhes: docs/AI_PROVIDERS.md
AI_PROVIDER=anthropic

# --- Provider padrão: Anthropic via relay Z.ai (GLM-4.6 — mais barato que Anthropic direta) ---
# NUNCA use ANTHROPIC_API_KEY real da console.anthropic.com em prod (caro). Use o relay Z.ai:
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_MODEL=glm-4.6
EXTRACTION_MODEL=glm-4.6
# (Alt: Anthropic direta — set ANTHROPIC_API_KEY=sk-ant-... e remova AUTH_TOKEN/BASE_URL)

# --- Alternativa 1: OpenAI (ou qualquer endpoint /chat/completions: Azure, OpenRouter, Together) ---
# Ative com: AI_PROVIDER=openai  +  descomente as 3
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Alternativa 2: Google Gemini ---
# Ative com: AI_PROVIDER=gemini  +  descomente as 2
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Se "true", NÃO chama a IA (usa rawExtraction salva ou devolve vazio).
# Útil p/ desenvolver UI/normalização sem gastar tokens.
EXTRACTION_DRY_RUN=false

# ===== Banco de dados (Postgres no Docker) =====
DATABASE_URL=postgresql://meus_exames:meus_exames_dev@localhost:5433/meus_exames?schema=public

# ===== Auth (JWT) =====
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# ===== Criptografia de PII (CPF/RG) =====
# Gere com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# ===== Servidor =====
PORT=4001
NODE_ENV=development
UPLOAD_DIR=./data/exams
WEB_ORIGIN=http://localhost:5173

# ===== Seed (1º usuário / paciente) =====
SEED_EMAIL=edmilson@exemplo.com
SEED_PASSWORD=troque123
SEED_NAME=Edmilson Lopes Fernandes dos Santos

# ===== E-mail transacional (SMTP) — reset de senha, etc. =====
# Ex.: Zoho: smtp.zoho.com / 587 / TLS (SMTP_SECURE=false)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=Meus Exames <no-reply@seudominio.com.br>

# ===== Pagamento (Mercado Pago) — igual ao EdEspeto =====
MP_ACCESS_TOKEN=
MP_API_BASE_URL=https://api.mercadopago.com
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=              # ex.: https://janocaminho.com.br/meus-exames/api/billing/webhook
FREE_EXAM_LIMIT=2
