// Meus Exames — modelo de dados
// Paciente (Edmilson) tem N exames; cada exame tem N itens (analitos);
// cada exame pode ter N análises de IA (resumo + turnos de chat).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(OWNER)
  blocked      Boolean  @default(false) // conta bloqueada pelo admin — login mostra msg amigável p/ contato com suporte (sem revelar o motivo)
  planExpiresAt DateTime?   // ativo enquanto no futuro (null = free/expirado)
  credits      Int      @default(60)   // créditos de IA — custos/grants parametrizados em app_settings. Recarrega com plano.
  emailVerified Boolean @default(false) // valida e-mail no cadastro (previne conta com e-mail fake)
  nudgeEmails   Boolean  @default(true) // recebe nudge de saúde por e-mail (fallback p/ quem NÃO tem push — ex.: iPhone no navegador)
  // Gamificação (conquistas): streak server-side (anti-farm) + pref de aviso de nova conquista
  streakDays        Int     @default(0)
  lastActiveDay     String? // YYYY-MM-DD do último dia ativo (idempotente no dia)
  achievementAlerts Boolean @default(true) // notifica (in-app) quando desbloqueia conquista
  referralCode String?  @unique  // código de indicação (ex: EDMILSON-A1B2) — vira bônus pra ambos
  referredBy   String?            // código de quem indicou este usuário
  deviceId     String?            // ID estável do aparelho (ANDROID_ID) — 1 bônus de boas-vindas por dispositivo
  // MFA (TOTP 2FA) — secret cifrado AES-256-GCM (null = desativado)
  mfaEnabled          Boolean   @default(false)
  mfaSecretEncrypted  String?
  mfaSecretIv         String?
  mfaSecretAuthTag    String?
  mfaConfirmedAt      DateTime?
  createdAt    DateTime @default(now())
  patients     Patient[]
  subscriptions Subscription[]
  deviceTokens DeviceToken[]
  notifications Notification[]
  deviceClaims DeviceClaim[] @relation("DeviceClaims")
  achievementGrants AchievementGrant[]
  creditTransactions CreditTransaction[]

  @@map("users")
}

// Bônus de boas-vindas já resgatado por dispositivo (deviceId @unique → 1 por aparelho, anti-farm).
// Mesmo se o usuário excluir a conta, o deviceId continua aqui → o aparelho não resgata de novo.
model DeviceClaim {
  id        String   @id @default(cuid())
  deviceId  String   @unique
  userId    String?
  user      User?    @relation("DeviceClaims", fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  @@map("device_claims")
}

// Conquista resgatada (gamificação): 1 crédito por badge, 1x só (anti-farm via unique).
model AchievementGrant {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, badgeId])
  @@map("achievement_grants")
}

// Extrato (ledger) de créditos: toda entrada/saída grava uma linha. Fonte única do Histórico de Uso.
model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int      // +ganho / -gasto (em créditos)
  kind      String   // purchase|plan_monthly|achievement|referral|signup|ai_chat|ai_summary|ai_consolidated|upload|share|patient_extra
  label     String   // descrição humana exibida no extrato
  refId     String?  // id do recurso (analysis/exam/grant/sub/share)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

// Config de monetização parametrizada no banco (lida no boot, editável pelo painel admin).
// key = categoria (creditCosts/uploadRules/grants/shares); value = objeto JSON.
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  @@map("app_settings")
}

enum Role {
  OWNER
  ADMIN
}

model Patient {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notes        DoctorNote[]
  fullName     String
  relationship String?   // parentesco: "Titular", "Filha", "Mãe", "Cônjuge"...
  gender       String?   // "male" | "female" — define a coluna de referência (Homens/Mulheres)
  dateOfBirth  DateTime?
  // PII criptografada (AES-256-GCM, chave APP_ENCRYPTION_KEY)
  cpfEncrypted String?
  cpfIv        String?
  // Perfil clínico livre (condições, medicações, histórico) — alimenta a IA de saúde.
  // Ex.: "Sem tireoide; usa levotiroxina (Levoid); usa testosterona; usa tirzepatida (Mounjaro)."
  clinicalProfile String?
  phone        String?
  photoUrl     String?
  uploadMonth        String?   // YYYY-MM do contador mensal de envios (cota grátis do premium)
  monthlyUploadCount Int       @default(0)  // envios neste mês — NÃO devolve ao deletar exame
  createdAt    DateTime  @default(now())
  exams        Exam[]
  reminders    Reminder[]
  measurements Measurement[]
  vaccines     Vaccine[]
  expenses     Expense[]
  doctorShares DoctorShare[]
  riskAssessments RiskAssessment[]

  @@index([ownerId])
  @@map("patients")
}

model Exam {
  id               String     @id @default(cuid())
  patientId        String
  patient          Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // metadados
  title            String
  kind             ExamKind   @default(OTHER)
  performedAt      DateTime?
  sourceLab        String?
  requestingDoctor String?

  // arquivo (fora do banco, em disco)
  filePath         String
  fileSha256       String
  fileSizeBytes    Int        @default(0)
  pageCount        Int        @default(0)

  // estado da extração
  status           ExamStatus @default(UPLOADED)
  rawExtraction    Json?
  reviewRequired   Boolean    @default(false)
  extractedAt      DateTime?
  extractionError  String?

  items            ExamItem[]
  analyses         AiAnalysis[]
  riskAssessments  RiskAssessment[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([patientId, fileSha256])
  @@index([patientId, performedAt])
  @@index([kind])
  @@map("exams")
}

enum ExamKind {
  LAB_PANEL
  IMAGING
  OTHER
}

enum ExamStatus {
  UPLOADED
  EXTRACTING
  EXTRACTED
  FAILED
}

model ExamItem {
  id            String   @id @default(cuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  // o analito
  panel         String?  // "Eritrograma" | "Leucograma" | "Série Plaquetária" ...
  name          String   // "HEMOGLOBINA" (como vem no exame)
  nameCanonical String   // chave normalizada p/ casar entre exames/labs: "HEMOGLOBINA"

  // valor (numérico preferido p/ evolução; texto como fallback)
  valueNumeric  Float?
  valueText     String?
  unit          String?

  // faixa de referência (coluna demográfica do paciente)
  refLow        Float?
  refHigh       Float?
  refText       String?
  refAppliesTo  String?  // "Homens" | "Mulheres" | "Adultos" ...

  // sinalização
  flag          ItemFlag @default(NORMAL)
  isAbnormal    Boolean  @default(false)

  // CITAÇÃO — página-fonte no PDF (1-indexed). Obrigatório p/ confiança.
  extractedPage Int

  // auditoria
  rawRow        Json?
  createdAt     DateTime @default(now())

  @@index([examId])
  @@index([nameCanonical, examId])
  @@map("exam_items")
}

enum ItemFlag {
  NORMAL
  HIGH
  LOW
  ABNORMAL
  CRITICAL
  UNKNOWN
}

model AiAnalysis {
  id               String        @id @default(cuid())
  examId           String?
  exam             Exam?         @relation(fields: [examId], references: [id], onDelete: Cascade)
  patientId        String?
  type             AnalysisType
  contentMd        String
  structured       Json?
  modelUsed        String?
  tokenUsage       Json?
  // encadeia turnos de chat sob um resumo
  parentAnalysisId String?
  userMessage      String?
  shareToken       String?       @unique  // link temporário pro médico ver
  sharePin         String?                // hash do PIN (6 dígitos) exigido pra abrir o link compartilhado
  createdAt        DateTime      @default(now())

  @@index([examId, type, createdAt])
  @@index([patientId, createdAt])
  @@map("ai_analyses")
}

enum AnalysisType {
  SUMMARY
  CHAT
}

// Avaliação de RISCO por condição (camada de regras clínicas — educativa, NÃO diagnóstica).
// Gerada por packages/server/src/analysis/risk-service.ts a partir do MarkerState + última PA.
// ML fica OFF por enquanto (dataset sintético); quando ligar, mlSuspect/basis passam a valer.
model RiskAssessment {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  examId          String?  // exame que disparou (opcional — pode ser roll-up do paciente)
  exam            Exam?    @relation(fields: [examId], references: [id], onDelete: Cascade)

  conditionKey    String   // none | prediabetes | diabetes | hypertension | high_cholesterol | cardiovascular_risk | anemia
  conditionLabel  String   // "Possível risco de diabetes" (PT, pronto p/ UI)
  riskLevel       String   // low | moderate | high
  confidence      Float    // confiança da análise combinada (não do modelo isolado)
  ruleConfidence  String   // alta | baixa
  basis           String   @default("rules") // rules (hoje) | ml_only (futuro)
  mlSuspect       Boolean  @default(false)   // ML disparou c/ painel cheio e regras limpas — só auditoria

  findings        Json     // findings[] auditáveis (cada um: key, value, unit, severity, condition, finding)
  doctorQuestions Json?    // perguntas sugeridas p/ o médico
  userExplanation String?  // explicação em linguagem simples (template; GLM pode refinar)
  snapshot        Json     // input canônico (valores por marcador — p/ reprodutibilidade/auditoria)

  createdAt       DateTime @default(now())

  @@index([patientId, createdAt])
  @@index([examId])
  @@map("risk_assessments")
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mpPaymentId    String?
  mpPreferenceId String?
  amount         Float
  periodDays     Int
  status         String   @default("PENDING") // PENDING | APPROVED | CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("subscriptions")
}

model Reminder {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ownerId   String
  title     String   // ex.: "Refazer hemograma"
  dueDate   DateTime
  note      String?
  done      Boolean  @default(false)
  // Antecedências escolhidas pelo usuário ao criar (estilo Agenda do Google), em MINUTOS antes do dueDate.
  // 1440=1 dia, 300=5h, 60=1h, 720=12h, 10080=1 semana, 0=na hora.
  notifyOffsetsMin Int[] @default([1440, 300, 0])
  // Offsets (em min) JÁ disparados — dedup persistente (sobrevive a restart/deploy; substitui o Set em memória).
  sentOffsets      Int[] @default([])
  createdAt DateTime @default(now())

  @@index([patientId, dueDate])
  @@map("reminders")
}

model Measurement {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type            String   // BLOOD_PRESSURE | WEIGHT | GLUCOSE | HEART_RATE | OTHER
  value           Float
  valueSecondary  Float?   // sistólica (quando type=BLOOD_PRESSURE)
  unit            String
  measuredAt      DateTime
  note            String?
  createdAt       DateTime @default(now())

  @@index([patientId, type, measuredAt])
  @@map("measurements")
}

model Vaccine {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String   // "Influenza", "COVID-19", "Tétano"...
  dateApplied  DateTime
  nextDoseDate DateTime?
  lot          String?  // lote da vacina
  note         String?
  createdAt    DateTime @default(now())

  @@index([patientId, dateApplied])
  @@map("vaccines")
}

model Expense {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ownerId     String
  description String
  category    String   // Exame | Consulta | Remédio | Outro
  amount      Float
  spentAt     DateTime
  createdAt   DateTime @default(now())

  @@index([patientId, spentAt])
  @@map("expenses")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String?  // android | web | ios
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

// Central de notificações (nudges de saúde do scheduler + histórico p/ o usuário)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'alert' | 'trend' | 'reminder' | 'info'
  title     String
  body      String
  data      Json?    // ex.: { examId, nameCanonical } p/ deep link
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// Portal do Médico — médico + compartilhamento seletivo de dados
model Doctor {
  id           String   @id @default(cuid())
  name         String
  crm          String   @unique
  crmUf        String?
  specialty    String?
  photoUrl     String?
  email        String   @unique
  emailVerified Boolean @default(false) // valida e-mail no cadastro (igual o paciente) — antes logava direto
  passwordHash String
  createdAt    DateTime @default(now())
  shares       DoctorShare[]
  notes        DoctorNote[]
  // MFA (TOTP 2FA) — mesmo esquema do User
  mfaEnabled          Boolean   @default(false)
  mfaSecretEncrypted  String?
  mfaSecretIv         String?
  mfaSecretAuthTag    String?
  mfaConfirmedAt      DateTime?

  @@map("doctors")
}

// Desafio MFA no login (transient — cria na senha OK, consome no verify do código).
model MfaChallenge {
  id              String   @id @default(cuid())
  tokenHash       String   @unique // SHA-256 do challengeToken (o cliente manda o original)
  ownerType       String   // 'USER' | 'DOCTOR'
  ownerId         String
  sessionPayload  Json     // sessão pendente pra emitir no sucesso (userId/doctorId)
  expiresAt       DateTime // TTL 5 min
  consumedAt      DateTime?
  attemptsCount   Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([ownerType, ownerId])
  @@map("mfa_challenges")
}

model DoctorShare {
  id         String    @id @default(cuid())
  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  scopes     String[]  // ['exams','evolution','alerts','summary'] — controle granular
  convenio   String?   // particular / convênio X
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  creditsCharged Int @default(0) // créditos debitados do paciente ao criar o share (pro extrato)

  @@unique([patientId, doctorId])
  @@index([doctorId, active])
  @@map("doctor_shares")
}

// Anotações clínicas do médico sobre um paciente compartilhado (histórico de atendimento)
model DoctorNote {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([doctorId, createdAt])
  @@map("doctor_notes")
}

// ===== BACKOFFICE — models de gestão (FKs escalares, append-only/standalone p/ não acoplar) =====

// Auditoria universal (LGPD): quem fez o quê, quando. Append-only.
// actorType: 'ADMIN' | 'DOCTOR' | 'SYSTEM'; action: 'BLOCK_USER' | 'UNBLOCK_USER' | 'GRANT_CREDITS' | 'DELETE_USER' | 'VIEW_SENSITIVE'...
model AuditLog {
  id          String   @id @default(cuid())
  actorType   String   // ADMIN | DOCTOR | SYSTEM
  actorId     String?  // id do admin/doctor (null = sistema)
  action      String
  targetType  String?  // USER | EXAM | DOCTOR | SUBSCRIPTION...
  targetId    String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  @@index([createdAt])
  @@index([actorType, actorId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// Uso de IA por requisição (custo/latência/sucesso) — separado do AiAnalysis (output paciente).
model AiUsageLog {
  id               String   @id @default(cuid())
  analysisId       String?  // fk ai_analyses (sem relation p/ não acoplar)
  userId           String?
  feature          String   // SUMMARY | CHAT | CONSOLIDATED | EXTRACTION
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costBrl          Float    @default(0)
  latencyMs        Int      @default(0)
  success          Boolean  @default(true)
  errorCode        String?
  requestId        String?
  createdAt        DateTime @default(now())
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@map("ai_usage_logs")
}

// Jobs de processamento (extração/IA) — fila, retries, duração. Decursa do Exam.status.
model ProcessingJob {
  id           String    @id @default(cuid())
  examId       String?
  type         String    // EXTRACT | AI_SUMMARY | AI_CHAT
  status       String    // QUEUED | RUNNING | DONE | FAILED
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  queuedAt     DateTime  @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  workerId     String?
  error        String?
  @@index([status, queuedAt])
  @@index([examId])
  @@map("processing_jobs")
}

// Campanha de push (broadcast segmentado) — fan-out vira Notification por usuário.
model PushCampaign {
  id             String   @id @default(cuid())
  name           String
  audienceFilter Json?    // { role?, hasExams?, plan? }
  title          String
  body           String
  route          String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  sentCount      Int      @default(0)
  deliveredCount Int      @default(0)
  failedCount    Int      @default(0)
  createdBy      String?
  createdAt      DateTime @default(now())
  @@index([createdAt])
  @@map("push_campaigns")
}

// Plano (preço/período/créditos/features) — primeira classe (tirar do JSON de settings).
model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  priceBrl      Float
  periodDays    Int      // 30 = mensal, 365 = anual, 0 = avulso
  creditsGranted Int     @default(0)
  features      Json?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  @@map("plans")
}

// Pagamento (ledger) — desacoplado de Subscription (refunds/retries/webhook raw).
model Payment {
  id             String    @id @default(cuid())
  subscriptionId String?
  userId         String
  mpPaymentId    String    @unique
  status         String    // APPROVED | PENDING | CANCELLED | FAILED | REFUNDED
  method         String?
  amountBrl      Float
  paidAt         DateTime?
  refundedAt     DateTime?
  rawWebhook     Json?
  createdAt      DateTime  @default(now())
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

// Chamado de suporte (paciente abre, admin responde — estilo Zendesk).
model SupportTicket {
  id            String          @id @default(cuid())
  number        Int             @unique @default(autoincrement()) // "#1234" (Postgres SERIAL)
  userId        String
  category      String?         // assunto pré-definido (ex.: "Erro no app")
  subject       String
  status        String          @default("open") // open | pending | closed
  priority      String          @default("normal") // low | normal | high
  assigneeId    String?         // admin id
  lastMessageBy String?         // 'user' | 'admin' (quem mandou a última msg)
  lastMessageAt DateTime?
  unreadByAdmin Boolean         @default(false) // usuário respondeu, admin não leu
  unreadByUser  Boolean         @default(false) // admin respondeu, usuário não leu
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  closedAt      DateTime?
  messages      TicketMessage[]
  @@index([status, updatedAt])
  @@index([userId, createdAt])
  @@map("support_tickets")
}

// Mensagem de uma thread de suporte (autor = user ou admin).
model TicketMessage {
  id          String         @id @default(cuid())
  ticketId    String
  authorRole  String         // 'user' | 'admin'
  authorId    String?        // userId (autor) ou id do admin
  body        String
  attachments Json?          // [{ref,name,size,type}] — refs resolvidos via storage (S3/disk)
  createdAt   DateTime       @default(now())
  ticket      SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}
