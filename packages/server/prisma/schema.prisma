// Meus Exames — modelo de dados
// Paciente (Edmilson) tem N exames; cada exame tem N itens (analitos);
// cada exame pode ter N análises de IA (resumo + turnos de chat).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(OWNER)
  planExpiresAt DateTime?   // ativo enquanto no futuro (null = free/expirado)
  credits      Int      @default(60)   // créditos de IA — custos/grants parametrizados em app_settings. Recarrega com plano.
  emailVerified Boolean @default(false) // valida e-mail no cadastro (previne conta com e-mail fake)
  nudgeEmails   Boolean  @default(true) // recebe nudge de saúde por e-mail (fallback p/ quem NÃO tem push — ex.: iPhone no navegador)
  // Gamificação (conquistas): streak server-side (anti-farm) + pref de aviso de nova conquista
  streakDays        Int     @default(0)
  lastActiveDay     String? // YYYY-MM-DD do último dia ativo (idempotente no dia)
  achievementAlerts Boolean @default(true) // notifica (in-app) quando desbloqueia conquista
  referralCode String?  @unique  // código de indicação (ex: EDMILSON-A1B2) — vira bônus pra ambos
  referredBy   String?            // código de quem indicou este usuário
  deviceId     String?            // ID estável do aparelho (ANDROID_ID) — 1 bônus de boas-vindas por dispositivo
  // MFA (TOTP 2FA) — secret cifrado AES-256-GCM (null = desativado)
  mfaEnabled          Boolean   @default(false)
  mfaSecretEncrypted  String?
  mfaSecretIv         String?
  mfaSecretAuthTag    String?
  mfaConfirmedAt      DateTime?
  createdAt    DateTime @default(now())
  patients     Patient[]
  subscriptions Subscription[]
  deviceTokens DeviceToken[]
  notifications Notification[]
  deviceClaims DeviceClaim[] @relation("DeviceClaims")
  achievementGrants AchievementGrant[]

  @@map("users")
}

// Bônus de boas-vindas já resgatado por dispositivo (deviceId @unique → 1 por aparelho, anti-farm).
// Mesmo se o usuário excluir a conta, o deviceId continua aqui → o aparelho não resgata de novo.
model DeviceClaim {
  id        String   @id @default(cuid())
  deviceId  String   @unique
  userId    String?
  user      User?    @relation("DeviceClaims", fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  @@map("device_claims")
}

// Conquista resgatada (gamificação): 1 crédito por badge, 1x só (anti-farm via unique).
model AchievementGrant {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, badgeId])
  @@map("achievement_grants")
}

// Config de monetização parametrizada no banco (lida no boot, editável pelo painel admin).
// key = categoria (creditCosts/uploadRules/grants/shares); value = objeto JSON.
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  @@map("app_settings")
}

enum Role {
  OWNER
  ADMIN
}

model Patient {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notes        DoctorNote[]
  fullName     String
  relationship String?   // parentesco: "Titular", "Filha", "Mãe", "Cônjuge"...
  gender       String?   // "male" | "female" — define a coluna de referência (Homens/Mulheres)
  dateOfBirth  DateTime?
  // PII criptografada (AES-256-GCM, chave APP_ENCRYPTION_KEY)
  cpfEncrypted String?
  cpfIv        String?
  // Perfil clínico livre (condições, medicações, histórico) — alimenta a IA de saúde.
  // Ex.: "Sem tireoide; usa levotiroxina (Levoid); usa testosterona; usa tirzepatida (Mounjaro)."
  clinicalProfile String?
  phone        String?
  photoUrl     String?
  uploadMonth        String?   // YYYY-MM do contador mensal de envios (cota grátis do premium)
  monthlyUploadCount Int       @default(0)  // envios neste mês — NÃO devolve ao deletar exame
  createdAt    DateTime  @default(now())
  exams        Exam[]
  reminders    Reminder[]
  measurements Measurement[]
  vaccines     Vaccine[]
  expenses     Expense[]
  doctorShares DoctorShare[]

  @@index([ownerId])
  @@map("patients")
}

model Exam {
  id               String     @id @default(cuid())
  patientId        String
  patient          Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // metadados
  title            String
  kind             ExamKind   @default(OTHER)
  performedAt      DateTime?
  sourceLab        String?
  requestingDoctor String?

  // arquivo (fora do banco, em disco)
  filePath         String
  fileSha256       String
  fileSizeBytes    Int        @default(0)
  pageCount        Int        @default(0)

  // estado da extração
  status           ExamStatus @default(UPLOADED)
  rawExtraction    Json?
  reviewRequired   Boolean    @default(false)
  extractedAt      DateTime?
  extractionError  String?

  items            ExamItem[]
  analyses         AiAnalysis[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([patientId, fileSha256])
  @@index([patientId, performedAt])
  @@index([kind])
  @@map("exams")
}

enum ExamKind {
  LAB_PANEL
  IMAGING
  OTHER
}

enum ExamStatus {
  UPLOADED
  EXTRACTING
  EXTRACTED
  FAILED
}

model ExamItem {
  id            String   @id @default(cuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  // o analito
  panel         String?  // "Eritrograma" | "Leucograma" | "Série Plaquetária" ...
  name          String   // "HEMOGLOBINA" (como vem no exame)
  nameCanonical String   // chave normalizada p/ casar entre exames/labs: "HEMOGLOBINA"

  // valor (numérico preferido p/ evolução; texto como fallback)
  valueNumeric  Float?
  valueText     String?
  unit          String?

  // faixa de referência (coluna demográfica do paciente)
  refLow        Float?
  refHigh       Float?
  refText       String?
  refAppliesTo  String?  // "Homens" | "Mulheres" | "Adultos" ...

  // sinalização
  flag          ItemFlag @default(NORMAL)
  isAbnormal    Boolean  @default(false)

  // CITAÇÃO — página-fonte no PDF (1-indexed). Obrigatório p/ confiança.
  extractedPage Int

  // auditoria
  rawRow        Json?
  createdAt     DateTime @default(now())

  @@index([examId])
  @@index([nameCanonical, examId])
  @@map("exam_items")
}

enum ItemFlag {
  NORMAL
  HIGH
  LOW
  ABNORMAL
  CRITICAL
  UNKNOWN
}

model AiAnalysis {
  id               String        @id @default(cuid())
  examId           String?
  exam             Exam?         @relation(fields: [examId], references: [id], onDelete: Cascade)
  patientId        String?
  type             AnalysisType
  contentMd        String
  structured       Json?
  modelUsed        String?
  tokenUsage       Json?
  // encadeia turnos de chat sob um resumo
  parentAnalysisId String?
  userMessage      String?
  shareToken       String?       @unique  // link temporário pro médico ver
  sharePin         String?                // hash do PIN (6 dígitos) exigido pra abrir o link compartilhado
  createdAt        DateTime      @default(now())

  @@index([examId, type, createdAt])
  @@index([patientId, createdAt])
  @@map("ai_analyses")
}

enum AnalysisType {
  SUMMARY
  CHAT
}

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mpPaymentId    String?
  mpPreferenceId String?
  amount         Float
  periodDays     Int
  status         String   @default("PENDING") // PENDING | APPROVED | CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@map("subscriptions")
}

model Reminder {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ownerId   String
  title     String   // ex.: "Refazer hemograma"
  dueDate   DateTime
  note      String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([patientId, dueDate])
  @@map("reminders")
}

model Measurement {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type            String   // BLOOD_PRESSURE | WEIGHT | GLUCOSE | HEART_RATE | OTHER
  value           Float
  valueSecondary  Float?   // sistólica (quando type=BLOOD_PRESSURE)
  unit            String
  measuredAt      DateTime
  note            String?
  createdAt       DateTime @default(now())

  @@index([patientId, type, measuredAt])
  @@map("measurements")
}

model Vaccine {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String   // "Influenza", "COVID-19", "Tétano"...
  dateApplied  DateTime
  nextDoseDate DateTime?
  lot          String?  // lote da vacina
  note         String?
  createdAt    DateTime @default(now())

  @@index([patientId, dateApplied])
  @@map("vaccines")
}

model Expense {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  ownerId     String
  description String
  category    String   // Exame | Consulta | Remédio | Outro
  amount      Float
  spentAt     DateTime
  createdAt   DateTime @default(now())

  @@index([patientId, spentAt])
  @@map("expenses")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String?  // android | web | ios
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("device_tokens")
}

// Central de notificações (nudges de saúde do scheduler + histórico p/ o usuário)
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'alert' | 'trend' | 'reminder' | 'info'
  title     String
  body      String
  data      Json?    // ex.: { examId, nameCanonical } p/ deep link
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// Portal do Médico — médico + compartilhamento seletivo de dados
model Doctor {
  id           String   @id @default(cuid())
  name         String
  crm          String   @unique
  crmUf        String?
  specialty    String?
  photoUrl     String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  shares       DoctorShare[]
  notes        DoctorNote[]
  // MFA (TOTP 2FA) — mesmo esquema do User
  mfaEnabled          Boolean   @default(false)
  mfaSecretEncrypted  String?
  mfaSecretIv         String?
  mfaSecretAuthTag    String?
  mfaConfirmedAt      DateTime?

  @@map("doctors")
}

// Desafio MFA no login (transient — cria na senha OK, consome no verify do código).
model MfaChallenge {
  id              String   @id @default(cuid())
  tokenHash       String   @unique // SHA-256 do challengeToken (o cliente manda o original)
  ownerType       String   // 'USER' | 'DOCTOR'
  ownerId         String
  sessionPayload  Json     // sessão pendente pra emitir no sucesso (userId/doctorId)
  expiresAt       DateTime // TTL 5 min
  consumedAt      DateTime?
  attemptsCount   Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([ownerType, ownerId])
  @@map("mfa_challenges")
}

model DoctorShare {
  id         String    @id @default(cuid())
  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  scopes     String[]  // ['exams','evolution','alerts','summary'] — controle granular
  convenio   String?   // particular / convênio X
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  creditsCharged Int @default(0) // créditos debitados do paciente ao criar o share (pro extrato)

  @@unique([patientId, doctorId])
  @@index([doctorId, active])
  @@map("doctor_shares")
}

// Anotações clínicas do médico sobre um paciente compartilhado (histórico de atendimento)
model DoctorNote {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([doctorId, createdAt])
  @@map("doctor_notes")
}
