# Dependências
node_modules/

# Builds
dist/
build/
*.tsbuildinfo

# Ambiente / segredos
.env
.env.local
.env.*.local

# Dados sensíveis (PDFs/fotos = PII sob LGPD; nunca commitar) — dirs de RUNTIME, NÃO o código em web/src/data
/data/
packages/server/data/
packages/data/
uploads/
samples/*.pdf
samples/*.jpg
samples/*.png

# Logs
*.log
npm-debug.log*

# SO / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Template AdminLTE (descartado — não faz parte do app)
AdminLTE/

# Android / Capacitor
packages/mobile/android/app/build/
packages/mobile/android/.gradle/
packages/mobile/android/local.properties
packages/mobile/android/captures/
packages/mobile/android/.idea/
packages/mobile/ios/App/App/Private/
android-build.log
.shot-*.png

# Firebase (config do projeto — local; o server usa serviceAccountKey.json separado)
**/google-services.json
**/google-services.*.json
**/serviceAccountKey.json
**/*firebase-adminsdk*.json
packages/mobile/android/app/keystore.properties
*.keystore

# Análise de código (regenerável — graphify/serena geram localmente)
graphify-out/
**/graphify-out/
.serena/cache/
.serena/memories/


# build temp do workaround de dist travado
packages/web/dist2/

# Build info gerado (versão/commit — regenerado a cada build; não commitar)
packages/*/src/generated/
packages/web/public/build-info.json

# Playwright (E2E do web) — artefatos regeneráveis, não commitar
packages/web/playwright-report/
packages/web/test-results/
packages/web/e2e/screenshots/
packages/web/playwright/.cache/
